# PBS Auth Service Configuration

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/pbs_auth

# JWT
JWT_SECRET_KEY=your-super-secret-jwt-key-change-in-production

# OAuth Providers - Google
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=https://api.pbs.local/auth/callback/google

# OAuth Providers - Apple
APPLE_CLIENT_ID=com.pbs.auth
APPLE_TEAM_ID=your-apple-team-id
APPLE_KEY_ID=your-apple-key-id
APPLE_PRIVATE_KEY=your-apple-private-key
APPLE_REDIRECT_URI=https://api.pbs.local/auth/callback/apple

# OAuth Providers - Discord
DISCORD_CLIENT_ID=your-discord-client-id
DISCORD_CLIENT_SECRET=your-discord-client-secret
DISCORD_REDIRECT_URI=https://api.pbs.local/auth/callback/discord

# OAuth Providers - Fortnite (Epic Games)
FORTNITE_CLIENT_ID=your-epic-games-client-id
FORTNITE_CLIENT_SECRET=your-epic-games-client-secret
FORTNITE_REDIRECT_URI=https://api.pbs.local/auth/callback/fortnite

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:8000,https://pbs.local

# Webhooks
WEBHOOK_SECRET=your-webhook-secret-for-signature
WEBHOOK_USER_CREATED=https://your-webhook-endpoint.com/user-created
WEBHOOK_USER_UPDATED=https://your-webhook-endpoint.com/user-updated
WEBHOOK_USER_DELETED=https://your-webhook-endpoint.com/user-deleted

# Redis (optional, for distributed rate limiting)
REDIS_URL=redis://localhost:6379

# Debug
DEBUG=false
LOG_LEVEL=info
